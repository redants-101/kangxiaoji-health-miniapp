.coming-soon {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: #f8faf8;
}

.coming-soon-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 48rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7e1;
  max-width: 560rpx;
  width: 100%;
}

.coming-soon-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.coming-soon-title {
  color: #14201a;
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
  text-align: center;
}

.coming-soon-desc {
  color: #65756d;
  font-size: 28rpx;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 36rpx;
}

.coming-soon-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: #168957;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.coming-soon-hint {
  margin-top: 32rpx;
  color: #8a9790;
  font-size: 24rpx;
  text-align: center;
}

/* 响应式 - 宽屏 */
.coming-soon.layout-wide {
  max-width: 1120px;
  margin: 0 auto;
}

/* 适老化 */
.coming-soon.ui-scale-large .coming-soon-title {
  font-size: 40rpx;
}

.coming-soon.ui-scale-large .coming-soon-desc {
  font-size: 30rpx;
}

.coming-soon.ui-scale-elder .coming-soon-title {
  font-size: 44rpx;
}

.coming-soon.ui-scale-elder .coming-soon-desc {
  font-size: 34rpx;
}

.coming-soon.ui-scale-elder .coming-soon-action {
  font-size: 32rpx;
  padding: 20rpx 48rpx;
}

.coming-soon.ui-scale-elder .coming-soon-icon {
  font-size: 112rpx;
}
