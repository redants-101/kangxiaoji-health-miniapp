.add-button.is-pressed,
.primary-mini.button-hover,
.primary-mini.btn-hover,
.primary-mini.is-pressed,
.invite-button.button-hover,
.invite-button.btn-hover,
.invite-button.is-pressed {
  background: #0e6f45;
  box-shadow: 0 2rpx 8rpx rgba(22, 137, 87, 0.12);
}

.quick-action.button-hover,
.quick-action.btn-hover,
.quick-action.is-pressed,
.secondary-button.button-hover,
.secondary-button.btn-hover,
.secondary-button.is-pressed,
.tag.button-hover,
.tag.btn-hover,
.tag.is-pressed,
.type-pill.button-hover,
.type-pill.btn-hover,
.type-pill.is-pressed,
.bell-button.button-hover,
.bell-button.btn-hover,
.bell-button.is-pressed,
.preview-button.button-hover,
.preview-button.btn-hover,
.preview-button.is-pressed,
.switch-button.button-hover,
.switch-button.btn-hover,
.switch-button.is-pressed,
.share-button.button-hover,
.share-button.btn-hover,
.share-button.is-pressed,
.load-button.button-hover,
.load-button.btn-hover,
.load-button.is-pressed,
.edit-button.button-hover,
.edit-button.btn-hover,
.edit-button.is-pressed,
.secondary-action.button-hover,
.secondary-action.btn-hover,
.secondary-action.is-pressed,
.segment.button-hover,
.segment.btn-hover,
.segment.is-pressed {
  background: #f3f8f5;
  border-color: #b4dec7;
}

.danger-button.button-hover,
.danger-button.btn-hover,
.danger-button.is-pressed,
.danger-action.button-hover,
.danger-action.btn-hover,
.danger-action.is-pressed,
.danger-row.button-hover,
.danger-row.btn-hover,
.danger-row.is-pressed {
  background: #f8dedb;
  border-color: #e6aaa5;
}

.link-button.button-hover,
.link-button.btn-hover,
.link-button.is-pressed,
.med-row.button-hover,
.med-row.btn-hover,
.med-row.is-pressed,
.plan-row.button-hover,
.plan-row.btn-hover,
.plan-row.is-pressed,
.task-row.button-hover,
.task-row.btn-hover,
.task-row.is-pressed,
.record-row.button-hover,
.record-row.btn-hover,
.record-row.is-pressed,
.action-row.button-hover,
.action-row.btn-hover,
.action-row.is-pressed,
.setting-row.button-hover,
.setting-row.btn-hover,
.setting-row.is-pressed {
