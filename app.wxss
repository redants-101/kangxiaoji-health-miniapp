page {
  min-height: 100%;
  background: #f2f5f2;
  color: #14201a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.btn {
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: transparent;
  line-height: 1.2;
}

.btn::after {
  border: 0;
}

button,
.btn,
.primary-button,
.secondary-button,
.danger-button,
.link-button,
.state-button,
.head-button,
.header-button,
.bell-button,
.preview-button,
.switch-button,
.alert-button,
.report-button,
.add-button,
.primary-mini,
.share-button,
.load-button,
.edit-button,
.invite-button,
.secondary-action,
.danger-action,
.quick-action,
.segment,
.tag,
.type-pill,
.task-row,
.record-row,
.action-row,
.danger-row,
.setting-row,
.med-row,
.plan-row {
  transition: transform 120ms ease, opacity 120ms ease, box-shadow 120ms ease, background-color 120ms ease, border-color 120ms ease, color 120ms ease;
}

button::after,
.btn::after {
  border: 0;
}

.button-hover,
.btn-hover,
.is-pressed {
  opacity: 0.94;
  transform: translateY(2rpx);
}

.primary-button.button-hover,
.primary-button.btn-hover,
.primary-button.is-pressed,
.state-button.button-hover,
.state-button.btn-hover,
.state-button.is-pressed,
.head-button.button-hover,
.head-button.btn-hover,
.head-button.is-pressed,
.header-button.button-hover,
.header-button.btn-hover,
.header-button.is-pressed,
.alert-button.button-hover,
.alert-button.btn-hover,
.alert-button.is-pressed,
.report-button.button-hover,
.report-button.btn-hover,
.report-button.is-pressed,
.add-button.button-hover,
