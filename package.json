{
  "devDependencies": {
    "canvas": "^3.2.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint services/ utils/ pages/ components/ --ext .js",
    "lint:fix": "eslint services/ utils/ pages/ components/ --ext .js --fix",
    "regression": "node scripts/health-api-regression.js"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)$": "$1"
    },
    "collectCoverageFrom": [
      "services/**/*.js",
      "utils/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
