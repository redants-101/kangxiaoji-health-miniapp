.record-detail-page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  background: #f2f5f2;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  color: #65756d;
  font-size: 28rpx;
}

.detail-content {
  padding-bottom: 48rpx;
}

.detail-header {
  margin-bottom: 32rpx;
}

.detail-title {
  color: #14201a;
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.detail-time {
  color: #65756d;
  font-size: 24rpx;
}

.detail-card {
  padding: 32rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7e1;
  text-align: center;
  margin-bottom: 24rpx;
}

.detail-value {
  color: #168957;
  font-size: 56rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.detail-unit {
  color: #65756d;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.detail-status {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-status.normal {
  background: #e5f4ec;
  color: #0e6f45;
}

.detail-status.warn {
  background: #fef5f5;
  color: #c8463a;
}

.detail-tip {
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.detail-tip.warn {
  background: #fef5f5;
  border: 1rpx solid #f0d5d3;
}

.detail-tip.normal {
  background: #e5f4ec;
  border: 1rpx solid #b4dec7;
}

.tip-icon {
  font-size: 28rpx;
  min-width: 28rpx;
}

.tip-text {
  color: #14201a;
  font-size: 24rpx;
  line-height: 1.4;
}

.detail-list {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7e1;
  margin-bottom: 24rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #dfe7e1;
}

.detail-item:last-child {
  border-bottom: 0;
}

.item-label {
  color: #65756d;
  font-size: 24rpx;
}

.item-value {
  color: #14201a;
  font-size: 26rpx;
  font-weight: 600;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.danger-button {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  background: #c8463a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
