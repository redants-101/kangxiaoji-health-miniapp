<view wx:if="{{isLoading}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">正在加载</view>
    <view class="state-meta">页面加载中...</view>
  </view>
</view>
<view wx:elif="{{loadError}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">加载失败</view>
    <view class="state-meta">{{loadError}}</view>
    <button class="state-button" bindtap="handleReload">重新加载</button>
  </view>
</view>
<view wx:else class="record-bg-page {{adaptive.scaleClass}} {{adaptive.layoutClass}}">
  <view class="form-section">
    <view class="form-title">血糖记录</view>
    
    <!-- 血糖输入 -->
    <view class="form-group">
      <view class="form-label">血糖值</view>
      <view class="glucose-input-row">
        <input
          class="glucose-input {{errors.glucose ? 'input-error' : ''}}"
          type="number"
          placeholder="血糖值"
          value="{{form.glucose}}"
          data-field="glucose"
          bindinput="handleFormChange"
          aria-label="血糖值输入框"
        />
        <view class="glucose-unit">mmol/L</view>
      </view>
      <view wx:if="{{errors.glucose}}" class="error-text">
        {{errors.glucose}}
      </view>
      <view wx:if="{{errors.glucose}}" class="field-error-notice notice danger">
        {{errors.glucose}}
      </view>
    </view>

    <!-- 测量场景 -->
    <view class="form-group">
      <view class="form-label">测量场景</view>
      <view class="meal-tag-row">
        <view
          wx:for="{{mealTags}}"
          wx:key="*this"
          class="meal-tag-button {{selectedMealTag === item ? 'meal-tag-active' : ''}}"
          data-tag="{{item}}"
          bindtap="handleMealTagSelect"
          role="button"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 测量时间 -->
    <view class="form-group">
      <view class="form-label">测量时间</view>
      <picker
        mode="time"
        value="{{measuredAt}}"
        bindchange="handleTimeChange"
        bindcancel="handlePickerCancel"
      >
        <view class="time-picker">
          {{measuredAt || '选择时间'}}
        </view>
      </picker>
      <view class="quick-time-row">
        <view
          wx:for="{{quickTimes}}"
          wx:key="value"
          class="quick-time-btn {{measuredAt === (item.value === 'now' ? currentTime : item.value === 'afterMeal' ? afterMealTime : item.value) ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="handleQuickTime"
          role="button"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <view class="form-label">备注（可选）</view>
      <textarea
        class="form-textarea"
        placeholder="添加备注信息"
        value="{{form.note}}"
        data-field="note"
        bindinput="handleFormChange"
        aria-label="备注输入框"
      />
    </view>

    <!-- 健康提示 -->
    <view wx:if="{{summaryTip}}" class="summary-tip {{summaryLevel}}">
      <view class="tip-icon">{{summaryLevel === 'warn' ? '⚠️' : 'ℹ️'}}</view>
      <view class="tip-text">{{summaryTip}}</view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="secondary-button" bindtap="handleCancel">取消</button>
    <button class="primary-button" bindtap="handleSave" disabled="{{!form.glucose}}">
      保存记录
    </button>
  </view>
</view>
