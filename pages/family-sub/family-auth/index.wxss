.auth-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 150rpx;
  background: #f8faf8;
}

.member-panel {
  padding: 30rpx;
  border-radius: 16rpx;
  border: 1rpx solid #cbe5d6;
  background: #ecf7f0;
}

.member-row,
.section-head,
.scope-row,
.activity-row {
  display: flex;
  align-items: center;
}

.member-row,
.section-head,
.scope-row {
  justify-content: space-between;
  gap: 24rpx;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #168957;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.member-main,
.row-main {
  flex: 1;
  min-width: 0;
}

.member-name {
  color: #14201a;
  font-size: 36rpx;
  font-weight: 900;
}

.member-meta,
.member-desc,
.scope-meta,
.activity-meta {
  color: #65756d;
  font-size: 25rpx;
  line-height: 1.45;
}

.member-meta {
  margin-top: 8rpx;
}

.member-status {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #b4dec7;
  color: #0e6f45;
  font-size: 24rpx;
  font-weight: 800;
}

.member-desc {
  margin-top: 22rpx;
  color: #4f6258;
}

.section {
  margin-top: 36rpx;
}

.scope-panel,
.activity-panel {
  margin-top: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dfe7e1;
  background: #ffffff;
  overflow: hidden;
}

.scope-row {
  min-height: 116rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #dfe7e1;
}

.scope-row:last-child,
.activity-row:last-child {
  border-bottom: 0;
}

.scope-title,
.activity-title {
  color: #14201a;
  font-size: 30rpx;
  font-weight: 850;
}

.scope-meta,
.activity-meta {
  margin-top: 8rpx;
}

.activity-row {
  gap: 18rpx;
  min-height: 104rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #dfe7e1;
}

.activity-dot {
  width: 16rpx;
  height: 16rpx;
  flex: 0 0 auto;
  border-radius: 50%;
  background: #168957;
}

.danger-button {
  width: 100%;
}
