<view wx:if="{{isLoading}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">正在加载历史记录</view>
    <view class="state-meta">加载完成后可查看历史用药记录。</view>
  </view>
</view>
<view wx:elif="{{loadError}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">历史记录加载失败</view>
    <view class="state-meta">{{loadError}}</view>
    <button class="state-button" bindtap="reloadPage">重新加载</button>
  </view>
</view>
<view wx:else class="history-page {{adaptive.scaleClass}} {{adaptive.layoutClass}}">

  <view class="section">
    <view class="range-bar">
      <view class="range-btn" bindtap="handleRangePrev">‹</view>
      <view class="range-label">{{rangeLabel}}</view>
      <view class="range-btn" bindtap="handleRangeNext">›</view>
    </view>

    <view class="filter-row">
      <button
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-button {{activeFilter === item.key ? 'filter-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleFilterChange"
      >
        {{item.label}}
      </button>
    </view>

    <view wx:if="{{summary.totalRecords}}" class="summary-bar">
      <text class="summary-text">共 {{summary.totalRecords}} 条记录</text>
      <text class="summary-detail">已服 {{summary.takenCount}} · 已跳过 {{summary.skippedCount}}</text>
    </view>
  </view>

  <view wx:if="{{!visibleGroups.length}}" class="empty-panel">
    <image class="empty-icon" src="/assets/icons/icon-empty.png" mode="aspectFit" />
    <view class="empty-title">暂无历史记录</view>
    <view class="empty-meta">该时段内没有服药确认记录。</view>
  </view>

  <view wx:else class="section">
    <block wx:for="{{visibleGroups}}" wx:key="date">
      <view class="date-group">
        <view class="date-header">{{item.dateLabel}}</view>
        <view class="record-list">
          <view
            wx:for="{{item.records}}"
            wx:for-item="record"
            wx:key="logId"
            class="confirm-row"
          >
            <view class="confirm-icon {{record.status === 'taken' ? 'icon-taken' : 'icon-skipped'}}">
              <image class="confirm-icon-img" src="/assets/icons/icon-medication.png" mode="aspectFit" />
            </view>
            <view class="confirm-main">
              <view class="confirm-name">{{record.name}} <text class="confirm-dosage">{{record.dosage}}</text></view>
              <view class="confirm-meta">
                <text class="confirm-time">{{record.time}}</text>
                <text class="confirm-status {{record.status === 'taken' ? 'status-taken' : 'status-skipped'}}">{{record.statusText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

</view>
