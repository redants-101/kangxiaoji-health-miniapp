.history-page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  background: #f2f5f2;
}

.page-state {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f5f2;
}

.state-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 48rpx 32rpx;
}

.state-title {
  color: #14201a;
  font-size: 32rpx;
  font-weight: 700;
}

.state-meta {
  color: #65756d;
  font-size: 24rpx;
}

.state-button {
  margin-top: 16rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: #168957;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.section {
  margin-bottom: 24rpx;
}

/* 日期范围选择 */
.range-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.range-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid #dfe7e1;
  color: #168957;
  font-size: 32rpx;
  font-weight: 700;
}

.range-label {
  color: #14201a;
  font-size: 28rpx;
  font-weight: 700;
  min-width: 200rpx;
  text-align: center;
}

/* 筛选条 */
.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-button {
  padding: 8rpx 16rpx;
  border: 1rpx solid #dfe7e1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #65756d;
  font-size: 24rpx;
  font-weight: 600;
}

.filter-button.filter-active {
  border-color: #168957;
  background: #e5f4ec;
  color: #0e6f45;
}

/* 统计栏 */
.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  background: #e5f4ec;
  margin-bottom: 16rpx;
}

.summary-text {
  color: #0e6f45;
  font-size: 24rpx;
  font-weight: 600;
}

.summary-detail {
  color: #4a7a5e;
  font-size: 22rpx;
}

/* 空状态 */
.empty-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
  gap: 16rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.5;
}

.empty-title {
  color: #14201a;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-meta {
  color: #65756d;
  font-size: 24rpx;
}

/* 日期分组 */
.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  color: #14201a;
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 确认记录行 - 复用 med-list 的 confirm-row 样式 */
.confirm-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7e1;
}

.confirm-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  overflow: hidden;
}

.confirm-icon.icon-taken {
  background: #e5f4ec;
}

.confirm-icon.icon-skipped {
  background: #fef3e2;
}

.confirm-icon-img {
  width: 24rpx;
  height: 24rpx;
}

.confirm-main {
  flex: 1;
}

.confirm-name {
  color: #14201a;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.confirm-dosage {
  color: #65756d;
  font-size: 24rpx;
  font-weight: 400;
}

.confirm-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.confirm-time {
  color: #8a9790;
  font-size: 22rpx;
}

.confirm-status {
  font-size: 22rpx;
  font-weight: 600;
}

.status-taken {
  color: #168957;
}

.status-skipped {
  color: #b36b00;
}
