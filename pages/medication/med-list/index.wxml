<view wx:if="{{isLoading}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">正在加载用药提醒</view>
    <view class="state-meta">今日待确认和长期用药计划会在加载后展示。</view>
  </view>
</view>
<view wx:elif="{{loadError}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">用药提醒加载失败</view>
    <view class="state-meta">{{loadError}}</view>
    <button class="state-button" bindtap="reloadPage">重新加载</button>
  </view>
</view>
<view wx:else class="med-page {{adaptive.scaleClass}} {{adaptive.layoutClass}}">

  <view class="section">
    <view class="section-title">今日待确认</view>
    <block wx:if="{{todayCards && todayCards.length}}">
      <view class="card-list">
        <view
          wx:for="{{todayCards}}"
          wx:key="id"
          class="med-card"
          data-id="{{item.id}}"
          data-pending-index="{{item.pendingIndex}}"
          bindtap="handleCardTap"
          aria-label="{{item.name}}，{{item.summary}}"
        >
          <view class="card-row-primary">
            <view class="card-name">{{item.name}}</view>
            <view class="card-dosage">{{item.dosage}}</view>
            <view class="card-progress">{{item.progress}}</view>
          </view>
          <view class="card-timeline">
            <view
              wx:for="{{item.logs}}"
              wx:for-item="log"
              wx:key="id"
              class="time-node {{log.status === 'taken' || log.status === 'skipped' ? 'is-done' : ''}} {{log.status === 'pending' || log.status === 'snoozed' ? 'is-pending' : ''}}"
              data-action="{{log.action}}"
              data-log-id="{{log.id}}"
              data-plan-id="{{item.id}}"
              bindtap="handleLogTap"
            >
              <view class="node-dot"></view>
              <view class="node-info">
                <view class="node-time">{{log.time}}</view>
                <view class="node-label">{{log.statusText}}</view>
              </view>
            </view>
          </view>
          <view class="card-action" wx:if="{{item.pendingIndex >= 0}}">
            <view class="action-highlight">{{item.logs[item.pendingIndex].time}} 待确认</view>
            <view class="action-btn" data-plan-id="{{item.id}}" data-log-id="{{item.logs[item.pendingIndex].id}}" bindtap="handleConfirmTap">确认</view>
          </view>
        </view>
      </view>
    </block>
    <view wx:else class="empty-panel">
      <image class="empty-icon" src="/assets/icons/icon-empty.png" mode="aspectFit" />
      <view class="empty-title">暂无待确认提醒</view>
      <view class="empty-meta">今日用药已全部确认，或尚未添加用药计划。</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">用药计划</view>
    <view class="list-panel">
      <block wx:if="{{plans && plans.length}}">
        <view
          wx:for="{{plans}}"
          wx:key="id"
          class="plan-row {{item.status === '已停用' ? 'is-disabled' : ''}}"
          data-id="{{item.id}}"
          data-status="{{item.status}}"
          bindtap="editPlan"
          bindlongpress="handlePlanLongPress"
          role="button"
          aria-label="{{item.name}}，{{item.schedule}}"
        >
          <view class="plan-icon">
            <image class="plan-icon-img" src="/assets/icons/icon-medication.png" mode="aspectFit" />
          </view>
          <view class="plan-main">
            <view class="plan-name">{{item.name}}</view>
            <view class="plan-schedule">{{item.schedule}}</view>
          </view>
          <view class="plan-status {{item.status === '启用' ? 'status-active' : 'status-stopped'}}">{{item.status}}</view>
          <view class="plan-arrow"></view>
        </view>
      </block>
      <view wx:else class="empty-panel">
        <image class="empty-icon" src="/assets/icons/icon-empty.png" mode="aspectFit" />
        <view class="empty-title">暂无用药计划</view>
        <view class="empty-meta">仅记录药名、剂量说明和提醒时间，不提供用药决策。</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">今日服药记录</view>
      <view class="section-link" bindtap="goMedHistory">查看历史 ›</view>
    </view>
    <block wx:if="{{confirmations && confirmations.length}}">
      <view class="list-panel">
        <view
          wx:for="{{confirmations}}"
          wx:key="id"
          class="confirm-row"
        >
          <view class="confirm-icon {{item.status === 'taken' ? 'icon-taken' : 'icon-skipped'}}">
            <view class="confirm-dot"></view>
          </view>
          <view class="confirm-main">
            <view class="confirm-name">{{item.name}} <text class="confirm-dosage">{{item.dosage}}</text></view>
            <view class="confirm-meta">
              <text class="confirm-time">{{item.time}}</text>
              <text class="confirm-status {{item.status === 'taken' ? 'status-taken' : 'status-skipped'}}">{{item.statusText}}</text>
            </view>
          </view>
          <view class="confirm-revoke" data-log-id="{{item.logId}}" bindtap="handleRevokeConfirmation">撤销</view>
        </view>
      </view>
    </block>
    <view wx:else class="confirm-empty">
      <view class="confirm-empty-text">暂无今日服药记录</view>
      <view class="confirm-empty-hint">确认用药后，记录会在此处显示。</view>
    </view>
  </view>

  <view class="section">
    <notice-bar text="用药信息由用户自行记录，请按医生或药师指导用药。" />
  </view>

  <fixed-action text="添加用药" bindactiontap="goMedEdit" />
</view>
