.data-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 48rpx;
  background: #F2F5F2;
}

.section {
  margin-bottom: 36rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #14201a;
  margin-bottom: 16rpx;
}

.danger-title {
  color: #c8463a;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.summary-card {
  padding: 24rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid #dfe7e1;
  text-align: center;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #168957;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #65756d;
}

/* 导出面板 */
.export-panel {
  border-radius: 16rpx;
  border: 1rpx solid #dfe7e1;
  background: #ffffff;
  padding: 28rpx;
}

.format-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #14201a;
  margin-bottom: 16rpx;
}

.format-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.format-card {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  border: 2rpx solid #dfe7e1;
  background: #f8faf8;
  text-align: center;
}

.format-card.active {
  border-color: #168957;
  background: #ecf7f0;
}

.format-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #14201a;
  margin-bottom: 6rpx;
}

.format-card.active .format-name {
  color: #168957;
}

.format-desc {
  font-size: 22rpx;
  color: #65756d;
}

.export-button {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  background: #168957;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

/* 操作面板 */
.action-panel {
  border-radius: 16rpx;
  border: 1rpx solid #dfe7e1;
  background: #ffffff;
  overflow: hidden;
}

.action-card {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #dfe7e1;
  text-align: left;
}

.action-card:last-child {
  border-bottom: 0;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-img {
  width: 36rpx;
  height: 36rpx;
}

.delete-icon {
  background: #fef0ef;
}

.clear-icon {
  background: #fef0ef;
}

.action-content {
  flex: 1;
  min-width: 0;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #14201a;
  margin-bottom: 6rpx;
}

.action-meta {
  font-size: 24rpx;
  color: #65756d;
}

.action-card.danger .action-title {
  color: #c8463a;
}

.action-chevron {
  flex: 0 0 auto;
  font-size: 40rpx;
  color: #c8c9cc;
  margin-left: 16rpx;
}

.action-card.danger .action-chevron {
  color: #e8a09c;
}

/* 导出结果弹窗 */
.export-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-body {
  position: relative;
  width: 90%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #14201a;
  margin-bottom: 24rpx;
}

.modal-scroll {
  max-height: 50vh;
  margin-bottom: 24rpx;
}

.modal-text {
  font-size: 24rpx;
  color: #4f6258;
  line-height: 1.6;
  word-break: break-all;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.copy-btn {
  background: #168957;
  color: #ffffff;
}

.close-btn {
  background: #f2f5f2;
  color: #65756d;
}

/* 适老化 */
.data-page.ui-scale-large .summary-grid {
  grid-template-columns: repeat(2, 1fr);
}

.data-page.ui-scale-elder .summary-grid {
  grid-template-columns: 1fr;
}

.data-page.ui-scale-large .action-title,
.data-page.ui-scale-large .format-name {
  font-size: 32rpx;
}

.data-page.ui-scale-elder .action-title,
.data-page.ui-scale-elder .format-name,
.data-page.ui-scale-elder .export-button {
  font-size: 36rpx;
}

.data-page.ui-scale-elder .action-meta,
.data-page.ui-scale-elder .format-desc {
  font-size: 28rpx;
}

.data-page.ui-scale-elder .format-row {
  flex-wrap: wrap;
}

.data-page.ui-scale-elder .format-card {
  min-width: 45%;
}
