<view wx:if="{{isLoading}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">正在加载家庭协同</view>
    <view class="state-meta">家属成员、授权范围和共享状态会在加载后展示。</view>
  </view>
</view>
<view wx:elif="{{loadError}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">家庭数据加载失败</view>
    <view class="state-meta">{{loadError}}</view>
    <button class="state-button" bindtap="reloadPage">重新加载</button>
  </view>
</view>
<!-- 家庭功能开发中，显示敬请期待占位。上线后移除 coming-soon 标签即可恢复下方原始内容 -->
<coming-soon
  wx:else
  title="家庭协同"
  description="家属共享与授权管理功能正在开发中，上线后你将能邀请家属查看健康记录和用药状态，方便日常陪伴。"
  icon="👨‍👩‍👧‍👦"
/>
