<view wx:if="{{isLoading}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">正在加载隐私说明</view>
    <view class="state-meta">请稍候，马上为你展示使用范围和协议入口。</view>
  </view>
</view>
<view wx:elif="{{loadError}}" class="page-state {{adaptive.scaleClass}}">
  <view class="state-panel">
    <view class="state-title">隐私说明加载失败</view>
    <view class="state-meta">{{loadError}}</view>
    <button class="state-button" bindtap="reloadPage">重新加载</button>
  </view>
</view>
<view wx:else class="privacy-page {{adaptive.scaleClass}} {{adaptive.layoutClass}}">
  <view class="hero">
    <view class="eyebrow">康小记</view>
    <view class="title">家庭健康记录工具</view>
    <view class="subtitle">专注于血压血糖记录、用药管理和健康提醒，支持家庭成员按授权共享记录，随时了解家人健康状态。</view>
  </view>

  <view class="section">
    <view class="scope-panel">
      <view wx:for="{{scopes}}" wx:key="title" class="scope-row">
        <view class="scope-icon">
          <image wx:if="{{item.iconSrc}}" class="scope-icon-img" src="{{item.iconSrc}}" mode="aspectFit" />
          <text wx:else>{{item.icon}}</text>
        </view>
        <view>
          <view class="scope-title">{{item.title}}</view>
          <view class="scope-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <button class="agree-row" bindtap="toggleAgree" aria-label="{{agreed ? '取消同意' : '同意'}}隐私政策和用户服务协议">
      <view class="checkbox {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
      <view class="agree-text">
        我已阅读并同意
        <text class="link-text" catchtap="goPrivacyPolicy">《隐私政策》</text>
        和
        <text class="link-text" catchtap="goUserAgreement">《用户服务协议》</text>
      </view>
    </button>
  </view>

  <view class="section">
    <notice-bar text="康小记仅用于家庭健康记录、提醒和趋势回顾，不提供诊断、治疗、处方或急救判断。" level="warn" />
  </view>

  <view class="bottom-actions">
    <button class="secondary-button" bindtap="goPrivacyPolicy" aria-label="查看隐私政策">查看政策</button>
    <button class="primary-button {{agreed ? '' : 'disabled'}}" disabled="{{!agreed}}" bindtap="startUse" aria-label="{{agreed ? '开始使用' : '请先同意协议后开始使用'}}">开始使用</button>
  </view>
</view>
