.legal-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 150rpx;
  background: #f8faf8;
}

.page-head {
  padding-top: 18rpx;
}

.eyebrow {
  color: #168957;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.title {
  color: #14201a;
  font-size: 40rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 14rpx;
  color: #65756d;
  font-size: 27rpx;
  line-height: 1.55;
}

.meta-row {
  margin-top: 22rpx;
  display: grid;
  gap: 8rpx;
  color: #65756d;
  font-size: 25rpx;
  line-height: 1.45;
}

.section {
  margin-top: 36rpx;
}

/* 目录 */
.toc-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #14201a;
  margin-bottom: 16rpx;
}

.toc-list {
  border-radius: 16rpx;
  border: 1rpx solid #dfe7e1;
  background: #ffffff;
  overflow: hidden;
}

.toc-item {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #eef2ee;
}

.toc-item:last-child {
  border-bottom: 0;
}

.toc-index {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 auto;
  border-radius: 10rpx;
  background: #ecf7f0;
  color: #168957;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.toc-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #14201a;
}

/* 正文面板 */
.legal-panel {
  border-radius: 16rpx;
  border: 1rpx solid #dfe7e1;
  background: #ffffff;
  overflow: hidden;
}

.legal-block {
  padding: 28rpx;
  border-bottom: 1rpx solid #dfe7e1;
}

.legal-block:last-child {
  border-bottom: 0;
}

.block-head {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
}

.block-index {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 auto;
  border-radius: 10rpx;
  background: #168957;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.block-title {
  color: #14201a;
  font-size: 32rpx;
  font-weight: 900;
}

.block-line {
  margin-top: 14rpx;
  color: #4f6258;
  font-size: 28rpx;
  line-height: 1.65;
  padding-left: 62rpx;
}

/* 适老化 */
.legal-page.ui-scale-large .title {
  font-size: 44rpx;
}

.legal-page.ui-scale-large .block-title {
  font-size: 34rpx;
}

.legal-page.ui-scale-large .block-line {
  font-size: 30rpx;
}

.legal-page.ui-scale-elder .title {
  font-size: 48rpx;
}

.legal-page.ui-scale-elder .block-title {
  font-size: 38rpx;
}

.legal-page.ui-scale-elder .block-line {
  font-size: 34rpx;
  padding-left: 0;
}

.legal-page.ui-scale-elder .toc-text {
  font-size: 32rpx;
}
