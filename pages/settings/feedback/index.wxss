.feedback-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 150rpx;
  background: #f8faf8;
}

.page-head {
  padding-top: 18rpx;
}

.eyebrow {
  color: #168957;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 0.05em;
  margin-bottom: 8rpx;
}

.title {
  color: #14201a;
  font-size: 40rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 14rpx;
  color: #65756d;
  font-size: 27rpx;
  line-height: 1.55;
}

.section {
  margin-top: 36rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #14201a;
  margin-bottom: 16rpx;
}

.required {
  color: #c8463a;
  margin-left: 4rpx;
}

/* 类型选择 */
.type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.type-pill {
  min-height: 68rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 2rpx solid #dfe7e1;
  background: #ffffff;
  color: #65756d;
  font-size: 26rpx;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-sizing: border-box;
  margin: 0;
}

.type-pill::after {
  border: none;
}

.type-pill.active {
  border-color: #168957;
  background: #ecf7f0;
  color: #0e6f45;
}

.type-pill.error {
  border-color: #c8463a;
}

/* 表单 */
.form-panel {
  margin-top: 30rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dfe7e1;
  background: #ffffff;
}

.field {
  margin-bottom: 30rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #14201a;
  margin-bottom: 14rpx;
  display: block;
}

.text-area {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #dfe7e1;
  background: #f8faf8;
  font-size: 28rpx;
  color: #14201a;
  line-height: 1.55;
  box-sizing: border-box;
}

.text-area.has-error {
  border-color: #c8463a;
  background: #fef8f8;
}

.text-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid #dfe7e1;
  background: #f8faf8;
  font-size: 28rpx;
  color: #14201a;
  box-sizing: border-box;
}

.text-input.has-error {
  border-color: #c8463a;
  background: #fef8f8;
}

.counter {
  margin-top: 10rpx;
  color: #9aa8a1;
  font-size: 24rpx;
  text-align: right;
}

.counter.near-limit {
  color: #c8463a;
}

.field-error {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #c8463a;
  font-weight: 600;
}

/* 适老化 */
.feedback-page.ui-scale-large .title {
  font-size: 44rpx;
}

.feedback-page.ui-scale-large .field-label {
  font-size: 30rpx;
}

.feedback-page.ui-scale-large .text-area,
.feedback-page.ui-scale-large .text-input {
  font-size: 30rpx;
}

.feedback-page.ui-scale-elder .title {
  font-size: 48rpx;
}

.feedback-page.ui-scale-elder .field-label {
  font-size: 34rpx;
}

.feedback-page.ui-scale-elder .text-area,
.feedback-page.ui-scale-elder .text-input {
  font-size: 34rpx;
}

.feedback-page.ui-scale-elder .type-pill {
  min-height: 80rpx;
  font-size: 30rpx;
}

.feedback-page.ui-scale-elder .text-area {
  min-height: 240rpx;
}

.feedback-page.ui-scale-elder .text-input {
  height: 96rpx;
}
